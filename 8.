class Tienda:
    def __init__(self, nombre):
        self.nombre = nombre
        self.productos = []

    def anadir_producto(self, producto):
        self.productos.append(producto)

    def eliminar_producto(self, producto):
        if producto in self.productos:
            self.productos.remove(producto)

    def obtener_productos(self):
        return self.productos

mi_tienda = Tienda("Supermercado Central")

mi_tienda.anadir_producto("Manzanas")
mi_tienda.anadir_producto("Leche")
mi_tienda.anadir_producto("Pan")


lista_productos = mi_tienda.obtener_productos()

print(f"Tienda: {mi_tienda.nombre}")
print(f"Productos disponibles: {lista_productos}")
mi_tienda.eliminar_producto("Leche")
print(f"Inventario renovado: {lista_productos}")
